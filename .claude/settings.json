{
  "hooks": {
    "SessionStart": [
      {
        "command": "git remote set-url origin \"$(git remote get-url origin | sed 's|https://|https://x-access-token:'\"${GH_TOKEN}\"'@|')\"",
        "timeout": 5000
      }
    ]
  },
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "loadOnDemand": true
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "loadOnDemand": true
    }
  }
}
